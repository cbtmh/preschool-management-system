# ==========================================
# DATABASE CONFIGURATION (Sử dụng service db)
# ==========================================
DB_URL=jdbc:postgresql://db:5432/preschool_db1
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ==========================================
# APPLICATION & SECURITY CONFIGURATION
# ==========================================
PORT=8080
# Thay '*' bằng domain của Web/App khi lên production (VD: https://my-preschool.com)
CORS_ALLOWED_ORIGIN_PATTERNS=*

# ĐỔI KEY NÀY TRƯỚC KHI LÊN PRODUCTION (Dùng key base64 256-bit)
JWT_SECRET=your_base64_encoded_256_bit_secret_key_here

# ==========================================
# 3RD PARTY SERVICES CONFIGURATION
# ==========================================
# Cloudinary (Quản lý hình ảnh)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Telegram Bot (Nhận thông báo sự cố)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Gmail SMTP (Gửi mail tự động)
SPRING_MAIL_USERNAME=your_email@gmail.com
# Sử dụng App Password (Mật khẩu ứng dụng) của Gmail, không dùng mật khẩu chính
SPRING_MAIL_PASSWORD=your_app_password_here
